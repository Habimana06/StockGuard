# =============================================================================
# StockGuard API — environment variables
# Copy this file to:  backend/.env
# (This file is for the backend only. Frontend uses frontend/.env.example)
# =============================================================================

# -----------------------------------------------------------------------------
# MySQL credentials (same as docker-compose.yml → mysql service)
# -----------------------------------------------------------------------------
#
# ROOT (admin — backups, MySQL Workbench, emergency access)
#   User:     root
#   Password: root
#
# APP USER (what the API should use — do not use root in DATABASE_URL)
#   User:     stockguard
#   Password: stockguard
#   Database: stockguard
#   Host:     127.0.0.1   (from your PC)  |  mysql  (from API inside Docker)
#   Port:     3306
#
# -----------------------------------------------------------------------------

# Prisma connection string
# • Local dev (API on your machine, MySQL in Docker):
DATABASE_URL="mysql://stockguard:stockguard@127.0.0.1:3306/stockguard"

# • If you run the API inside Docker, compose overrides host to "mysql" automatically.

# Auth (required, at least 16 characters)
JWT_SECRET="replace-with-a-long-random-secret"

# Server
PORT=4000
CORS_ORIGIN=http://localhost:5173
RESERVATION_TTL_MINUTES=5
