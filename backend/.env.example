# =============================================================================
# StockGuard API — copy to backend/.env
# =============================================================================

# --- MySQL (docker-compose.yml) ---
#
# ROOT (admin — Workbench, etc.)
#   User:     root
#   Password: 62001
#
# APP (use this in DATABASE_URL)
#   User:     stockguard
#   Password: stockguard
#   Database: stockguard
#
# From your PC the container is on port 3307 (not 3306 — avoids conflict with local MySQL)
# Inside Docker the API uses host "mysql" on port 3306 (compose sets this automatically)

DATABASE_URL="mysql://stockguard:stockguard@127.0.0.1:3307/stockguard"

JWT_SECRET="replace-with-a-long-random-secret-min-16-chars"
PORT=4000
CORS_ORIGIN=http://localhost:5173
RESERVATION_TTL_MINUTES=5
